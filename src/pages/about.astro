---
import BaseLayout from '../layouts/BaseLayout.astro';

const locale = 'en';

const skills = [
  { category: 'Languages & Frameworks', items: ['.NET / C#', 'Python', 'TypeScript', 'Angular', 'FastAPI'] },
  { category: 'AI & Machine Learning', items: ['PyTorch', 'Transformers / BERT', 'LangChain', 'LangGraph', 'Semantic Kernel', 'AutoGen', 'RAG / Vector Search'] },
  { category: 'Cloud & Data', items: ['Azure (AI, Data, Fundamentals)', 'AWS', 'Azure Databricks', 'Microsoft Fabric', 'Azure AI Search', 'Pinecone', 'Chroma'] },
  { category: 'Databases', items: ['SQL Server', 'PostgreSQL', 'DynamoDB', 'Redis', 'CosmosDB'] },
  { category: 'DevOps & Tools', items: ['GitHub Actions', 'Azure Pipelines', 'Docker', 'GitHub Copilot', 'Claude Code'] },
];

const timeline = [
  { year: '2024 – now', role: 'Software Engineer', org: 'Microsoft', desc: 'Building AI-driven data pipelines on Azure Databricks and Microsoft Fabric for the M365 ecosystem. Led development of an AI agent for Sales Process optimization at the Internal Global Hackathon 2025.' },
  { year: '2025 – now', role: 'Collaborating Professor', org: 'Universitat Oberta de Catalunya', desc: 'Bridging theory and practice for master\'s students in professional software engineering courses. Remote collaboration from Ecuador with students across Spain and Latin America.' },
  { year: '2018 – 2024', role: 'Software Consultant', org: 'SoftwareMind', desc: 'Designed microservices architectures with .NET and FastAPI. Orchestrated AWS EventBridge/Lambda webhook systems. Led a team of 5 developers managing CI/CD on Azure Pipelines.' },
  { year: '2010 – 2024', role: 'Independent Developer', org: 'Ecuador', desc: 'Ran an independent software consultancy serving clients including DirecTV Ecuador, Merck, Presidencia del Ecuador, and international clients in Spain, Israel, the US, and New Zealand.' },
];
---

<BaseLayout
  title="About"
  description="Software Engineer at Microsoft, ML Specialist, and Professor at UOC. 15+ years building scalable systems."
  locale={locale}
>
  <div class="about-page section">
    <div class="container">

      <!-- Intro -->
      <div class="intro-grid">
        <div class="intro-text">
          <p class="eyebrow">About me</p>
          <h1 class="intro-title">Alexis Alulema</h1>
          <p class="intro-roles">Software Engineer · ML Specialist · Educator</p>
          <p class="intro-bio">
            I'm a software engineer based in Ecuador with over 15 years of experience building scalable systems — from enterprise .NET backends to production ML pipelines. Currently at <strong>Microsoft</strong>, where I work on AI-driven data engineering for the Microsoft 365 ecosystem using Azure Databricks and Microsoft Fabric.
          </p>
          <p class="intro-bio">
            Alongside my engineering work, I collaborate part-time as a <strong>professor at the Universitat Oberta de Catalunya</strong> (Barcelona), helping master's students connect theoretical foundations with real-world software practice.
          </p>
          <p class="intro-bio">
            My technical focus has shifted significantly toward <strong>AI and LLMs</strong> over the past few years — from building BERT-based classifiers and publishing NLP research to designing multi-agent systems with LangGraph and Semantic Kernel.
          </p>
          <div class="intro-links">
            <a href="https://github.com/alulema" target="_blank" rel="noopener noreferrer" class="social-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"/></svg>
              GitHub
            </a>
            <a href="https://www.linkedin.com/in/alulema" target="_blank" rel="noopener noreferrer" class="social-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
          </div>
        </div>

        <!-- Stats -->
        <div class="stats-grid">
          <div class="stat-card card">
            <span class="stat-number">15+</span>
            <span class="stat-label">Years of experience</span>
          </div>
          <div class="stat-card card">
            <span class="stat-number">2</span>
            <span class="stat-label">Current roles</span>
          </div>
          <div class="stat-card card">
            <span class="stat-number">1</span>
            <span class="stat-label">Published paper</span>
          </div>
          <div class="stat-card card">
            <span class="stat-number">7+</span>
            <span class="stat-label">Certifications</span>
          </div>
        </div>
      </div>

      <!-- Skills -->
      <section class="skills-section">
        <h2 class="section-title">Technical skills</h2>
        <div class="skills-grid">
          {skills.map(group => (
            <div class="skill-group card">
              <h3 class="skill-category">{group.category}</h3>
              <div class="skill-items">
                {group.items.map(item => <span class="badge">{item}</span>)}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Timeline -->
      <section class="timeline-section">
        <h2 class="section-title">Experience</h2>
        <div class="timeline">
          {timeline.map((item, i) => (
            <div class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <span class="timeline-year">{item.year}</span>
                <h3 class="timeline-role">{item.role} <span class="timeline-org">@ {item.org}</span></h3>
                <p class="timeline-desc">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Education -->
      <section class="edu-section">
        <h2 class="section-title">Education</h2>
        <div class="edu-grid">
          <div class="card edu-card">
            <span class="edu-degree">M.S. in Computer Engineering (IoT)</span>
            <span class="edu-school">University of New Mexico, USA</span>
          </div>
          <div class="card edu-card">
            <span class="edu-degree">B.S. in Electronics Engineering</span>
            <span class="edu-school">Universidad de las Fuerzas Armadas ESPE, Ecuador</span>
          </div>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .about-page { padding-bottom: 5rem; }

  .eyebrow {
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 0.75rem;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-bottom: 5rem;
  }

  @media (min-width: 768px) {
    .intro-grid { grid-template-columns: 1fr auto; align-items: start; }
  }

  .intro-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 0.375rem;
  }

  .intro-roles {
    font-size: 1rem;
    font-family: var(--font-mono);
    color: var(--color-accent);
    margin: 0 0 1.5rem;
  }

  .intro-bio {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    max-width: 42rem;
    margin: 0 0 1rem;
  }

  .intro-bio strong { color: var(--color-text); }

  .intro-links {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .social-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    min-width: 14rem;
  }

  .stat-card {
    text-align: center;
    padding: 1.25rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-number {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 1.75rem;
    color: var(--color-text);
  }

  /* Skills */
  .skills-section { margin-bottom: 5rem; }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
    gap: 1rem;
  }

  .skill-group { padding: 1.25rem; }

  .skill-category {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    font-family: var(--font-mono);
    margin: 0 0 0.875rem;
  }

  .skill-items { display: flex; flex-wrap: wrap; gap: 0.375rem; }

  /* Timeline */
  .timeline-section { margin-bottom: 5rem; }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-left: 1px solid var(--color-border);
    padding-left: 2rem;
    margin-left: 0.5rem;
  }

  .timeline-item {
    position: relative;
    padding-bottom: 2.5rem;
  }

  .timeline-item:last-child { padding-bottom: 0; }

  .timeline-marker {
    position: absolute;
    left: -2.5rem;
    top: 0.375rem;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--color-accent);
    border: 2px solid var(--color-bg);
    box-shadow: 0 0 0 1px var(--color-accent);
  }

  .timeline-year {
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    color: var(--color-accent);
    display: block;
    margin-bottom: 0.375rem;
  }

  .timeline-role {
    font-size: 1.0625rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: var(--color-text);
  }

  .timeline-org {
    font-weight: 400;
    color: var(--color-text-muted);
  }

  .timeline-desc {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
    max-width: 48rem;
  }

  /* Education */
  .edu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
    gap: 1rem;
  }

  .edu-card {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .edu-degree {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .edu-school {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }
</style>
