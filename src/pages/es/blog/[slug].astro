---
export const prerender = true;
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getReadingTime } from '../../../utils/reading-time';

export async function getStaticPaths() {
  const posts = await getCollection('blog-es', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const readingTime = getReadingTime(post.body ?? '');

const formattedDate = post.data.publishDate.toLocaleDateString('es-ES', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const updatedDate = post.data.updatedDate?.toLocaleDateString('es-ES', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  locale="es"
  ogImage={post.data.coverImage}
>
  <article class="post-article section">
    <div class="container container--narrow">

      {post.data.coverImage && (
        <img
          src={post.data.coverImage}
          alt={post.data.title}
          class="post-cover"
          loading="eager"
          decoding="async"
        />
      )}

      <header class="post-header">
        <div class="post-meta">
          <time datetime={post.data.publishDate.toISOString()}>{formattedDate}</time>
          <span>{readingTime} min de lectura</span>
          {updatedDate && <span>Actualizado: {updatedDate}</span>}
        </div>

        <h1 class="post-title">{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>

        <div class="post-tags">
          {post.data.tags.map((tag) => <span class="badge">{tag}</span>)}
        </div>
      </header>

      <div class="post-content prose">
        <Content />
      </div>

      <footer class="post-footer">
        <a href="/es/blog" class="back-link">← Volver al blog</a>
      </footer>

    </div>
  </article>
</BaseLayout>

<style>
  .container--narrow { max-width: 48rem; }

  .post-cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .post-header { margin-bottom: 3rem; }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .post-meta span::before { content: '·'; margin-right: 1rem; }

  .post-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
    line-height: 1.2;
  }

  .post-description {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    margin: 0 0 1.5rem;
    line-height: 1.7;
  }

  .post-tags { display: flex; flex-wrap: wrap; gap: 0.375rem; }

  .prose {
    color: var(--color-text);
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 2.5rem 0 1rem;
    letter-spacing: -0.02em;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.5rem;
  }

  .prose :global(h3) { font-size: 1.25rem; font-weight: 700; margin: 2rem 0 0.75rem; }
  .prose :global(h4) { font-size: 1.0625rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
  .prose :global(p) { margin: 1.25rem 0; }
  .prose :global(ul), .prose :global(ol) { margin: 1.25rem 0; padding-left: 1.5rem; }
  .prose :global(li) { margin: 0.375rem 0; }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    margin: 1.5rem 0;
    padding: 0.75rem 1.25rem;
    background-color: var(--color-bg-secondary);
    border-radius: 0 0.5rem 0.5rem 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .prose :global(code) {
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    padding: 0.15em 0.4em;
    font-size: 0.875em;
  }

  .prose :global(pre code) { background: none; border: none; padding: 0; }
  .prose :global(img) { max-width: 100%; border-radius: 0.5rem; margin: 1.5rem auto; display: block; }
  .prose :global(a) { color: var(--color-accent); text-decoration: underline; text-underline-offset: 3px; }

  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.9375rem; }
  .prose :global(th) { background-color: var(--color-bg-secondary); padding: 0.625rem 1rem; text-align: left; font-weight: 600; border-bottom: 2px solid var(--color-border); }
  .prose :global(td) { padding: 0.625rem 1rem; border-bottom: 1px solid var(--color-border); }
  .prose :global(hr) { border: none; border-top: 1px solid var(--color-border); margin: 2.5rem 0; }

  .post-footer { margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--color-border); }

  .back-link {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .back-link:hover { color: var(--color-accent); }
</style>
