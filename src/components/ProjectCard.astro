---
import type { Project } from '../data/projects';
import type { Locale } from '../i18n';

interface Props {
  project: Project;
  locale: Locale;
}

const { project, locale } = Astro.props;

const title       = locale === 'es' ? project.titleEs       : project.title;
const description = locale === 'es' ? project.descriptionEs : project.description;
const requestLabel  = locale === 'es' ? 'Solicitar acceso'  : 'Request access';
const offlineLabel  = locale === 'es' ? 'Apagado'           : 'Offline';
const categoryUrl   = `https://${project.subdomain}`;
---

<article class="project-card card" data-project-id={project.id}>
  {project.coverImage && (
    <div class="card-image-wrap">
      <img src={project.coverImage} alt={title} class="card-image" loading="lazy" decoding="async" />
    </div>
  )}

  <div class="card-body">
    <!-- Status badge — updated dynamically by client script -->
    <div class="card-top">
      <span class="status-badge" data-status="offline">
        <span class="status-dot"></span>
        <span class="status-label">{offlineLabel}</span>
      </span>
      {project.githubUrl && (
        <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="github-link" aria-label="View source on GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"/>
          </svg>
        </a>
      )}
    </div>

    <h2 class="card-title">{title}</h2>
    <p class="card-description">{description}</p>

    <div class="card-stack">
      {project.techStack.map(tech => <span class="badge">{tech}</span>)}
    </div>

    <!-- CTA — swapped dynamically based on status -->
    <div class="card-cta">
      <!-- Offline state -->
      <button
        class="btn-request cta-offline"
        data-project-id={project.id}
        data-project-title={title}
        data-subdomain={project.subdomain}
        data-locale={locale}
      >
        {requestLabel}
      </button>

      <!-- Pending state (hidden by default) -->
      <span class="cta-pending" hidden>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        {locale === 'es' ? 'Aprobación pendiente' : 'Pending approval'}
      </span>

      <!-- Active state (hidden by default) -->
      <a class="btn-open-demo cta-active" href={categoryUrl} target="_blank" rel="noopener noreferrer" hidden>
        {locale === 'es' ? 'Abrir demo' : 'Open demo'}
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
      <span class="demo-timer cta-active" hidden></span>
    </div>
  </div>
</article>

<style>
  .project-card {
    padding: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .card-image-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .project-card:hover .card-image {
    transform: scale(1.03);
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    flex: 1;
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Status badge */
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-family: var(--font-mono);
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--color-text-muted);
  }

  .status-badge[data-status="active"]  .status-dot { background-color: #4ade80; box-shadow: 0 0 6px #4ade80; }
  .status-badge[data-status="pending"] .status-dot { background-color: #fbbf24; }
  .status-badge[data-status="offline"] .status-dot { background-color: var(--color-text-muted); }

  .status-badge[data-status="active"]  .status-label { color: #4ade80; }
  .status-badge[data-status="pending"] .status-label { color: #fbbf24; }
  .status-badge[data-status="offline"] .status-label { color: var(--color-text-muted); }

  .github-link {
    color: var(--color-text-muted);
    display: flex;
    transition: color var(--transition-fast);
  }

  .github-link:hover { color: var(--color-accent); }

  .card-title {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
    color: var(--color-text);
  }

  .card-description {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: auto;
  }

  .card-cta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
  }

  .btn-request {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
    border: 1px solid var(--color-accent);
    background: none;
    color: var(--color-accent);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .btn-request:hover {
    background-color: var(--color-accent);
    color: #0a0f1e;
  }

  .btn-open-demo {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
    background-color: #4ade80;
    color: #0a0f1e;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: background-color var(--transition-fast);
  }

  .btn-open-demo:hover { background-color: #86efac; color: #0a0f1e; }

  .cta-pending {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    color: #fbbf24;
  }

  .demo-timer {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: #4ade80;
  }
</style>
