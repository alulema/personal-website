# Cloudflare Turnstile
# Get your site key at: https://dash.cloudflare.com/ → Turnstile
# The "1x00000000000000000000AA" key is Cloudflare's always-pass test key (dev only)
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Contact form — email destination
# Used by the Azure Function to send messages
CONTACT_DESTINATION_EMAIL=contact@alexisalulema.com

# Azure Communication Services (for sending emails)
AZURE_COMMUNICATION_CONNECTION_STRING=your-connection-string

# Demo on-demand system
JWT_SECRET=your-random-secret-min-32-chars
ADMIN_EMAIL=contact@alexisalulema.com

# Azure Storage (for demo request tickets)
AZURE_STORAGE_CONNECTION_STRING=your-storage-connection-string
